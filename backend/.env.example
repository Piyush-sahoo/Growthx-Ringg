# Copy to .env and fill in. Never commit the real .env.

# App
ENVIRONMENT=development

# Ringg AI — https://docs.ringg.ai  (claim credits: coupon RINGG-BUILDATHON-BLR)
# Auth uses the X-API-KEY header. See info/ringg-ai-skill.md.
RINGG_API_KEY=
RINGG_BASE_URL=https://prod-api.ringg.ai/ca/api/v0
# agent_id from GET /agent/all (your outbound assistant).
RINGG_ASSISTANT_ID=
# Caller id from GET /workspace/numbers (preferred over a raw number).
RINGG_FROM_NUMBER_ID=
# Optional shared secret; if set, inbound webhooks must send X-Webhook-Secret.
RINGG_WEBHOOK_SECRET=

# CORS — comma-separated frontend origins.
CORS_ORIGINS=http://localhost:3000
